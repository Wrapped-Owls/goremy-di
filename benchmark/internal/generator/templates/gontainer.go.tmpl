{{define "value_call_args"}}
    {{- if .Dependencies -}}({{range $index, $dep := .Dependencies}}{{if $index}}, {{end}}{{if $dep.ValueVar}}{{$dep.ValueVar}}{{else}}{{$dep.Type.VarName}}{{end}}{{end}}){{else}}(){{end}}
{{end}}

{{define "op_init_container"}}{{end}}

{{define "op_create_value"}}{{end}}

{{define "op_register_singleton"}}
        gontainer.NewFactory({{.Type.Constructor}}),
{{end}}

{{define "op_register_factory"}}
        gontainer.NewFactory({{.Type.Constructor}}),
{{end}}

{{define "op_register_instance"}}
        gontainer.NewService({{if .ValueVar}}{{.ValueVar}}{{else}}{{.Type.VarName}}{{end}}),
{{end}}

{{define "op_retrieve"}}
        if err := resolver.Resolve(new({{.Type.Type}})); err != nil {
            b.Fatal(err)
        }
{{end}}

{{define "op_retrieve_ignore_error"}}
        _ = resolver.Resolve(new({{.Type.Type}}))
{{end}}

{{define "file"}}
//go:build {{.BuildTag}}
// +build {{.BuildTag}}
// Code generated by go generate; DO NOT EDIT.

package tests

import (
    "testing"
{{- range .Imports }}
"{{.}}"
{{- end }}
)

{{range .Benchmarks}}
func Benchmark{{.Name}}(b *testing.B) {
{{- if .Setup}}
{{- $useResolver := true -}}
{{- range .Setup}}{{if eq .Kind "register_factory"}}{{$useResolver = false}}{{end}}{{end}}
{{- $loopLen := len .Loop -}}
{{- if gt $loopLen 1}}{{$useResolver = false}}{{end}}
{{- range .Setup}}{{if eq .Kind "create_value"}}
    {{.ValueVar}} := {{.Type.Constructor}}{{template "value_call_args" .}}
{{- end}}{{end}}
    if err := gontainer.Run(
{{- template "ops" .Setup}}
{{- if $useResolver}}
        gontainer.NewEntrypoint(func(resolver *gontainer.Resolver) {
            b.ReportAllocs()
            b.ResetTimer()
            for i := 0; i < b.N; i++ {
{{template "ops" .Loop}}
            }
            b.StopTimer()
        }),
{{- else}}
        gontainer.NewEntrypoint(func(invoker *gontainer.Invoker) {
            b.ReportAllocs()
            b.ResetTimer()
            for i := 0; i < b.N; i++ {
{{- range .Loop}}
{{- if eq .Kind "retrieve"}}
                if _, err := invoker.Invoke({{.Type.Constructor}}); err != nil {
                    b.Fatal(err)
                }
{{- else if eq .Kind "retrieve_ignore_error"}}
                _, _ = invoker.Invoke(func(_ {{.Type.Type}}) {})
{{- end}}
{{- end}}
            }
            b.StopTimer()
        }),
{{- end}}
    ); err != nil {
        b.Fatal(err)
    }
{{- else}}
    b.ReportAllocs()
    b.ResetTimer()
    for i := 0; i < b.N; i++ {
        if err := gontainer.Run(
{{- template "ops" .Loop}}
            gontainer.NewEntrypoint(func() {}),
        ); err != nil {
            b.Fatal(err)
        }
    }
{{- end}}
}
{{end}}{{end}}
